{
  "name": "antigravity-mission-control",
  "displayName": "Antigravity Mission Control",
  "description": "%extension.description%",
  "version": "1.0.0",
  "publisher": "anbudev",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anbu-2006/Antigravity-Mission-Control.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-mission-control.refreshAccounts",
        "title": "%command.refreshAccounts%",
        "icon": "$(refresh)"
      },
      {
        "command": "antigravity-mission-control.switchAccount",
        "title": "%command.switchAccount%"
      },
      {
        "command": "antigravity-mission-control.refreshAccount",
        "title": "%command.refreshAccount%"
      },
      {
        "command": "antigravity-mission-control.refreshAllAccounts",
        "title": "%command.refreshAllAccounts%"
      },
      {
        "command": "antigravity-mission-control.openDashboard",
        "title": "%command.openDashboard%"
      },
      {
        "command": "antigravity-mission-control.addAccount",
        "title": "%command.addAccount%",
        "icon": "$(add)"
      },
      {
        "command": "antigravity-mission-control.openSwitchLogs",
        "title": "%command.openSwitchLogs%"
      },
      {
        "command": "antigravity-mission-control.diagnoseEnvironment",
        "title": "%command.diagnoseEnvironment%"
      },
      {
        "command": "antigravity-mission-control.checkTerminalHealth",
        "title": "Antigravity: Check Terminal Health"
      },
      {
        "command": "antigravity-mission-control.loginWithToken",
        "title": "Antigravity: Login with Refresh Token",
        "icon": "$(key)"
      },
      {
        "command": "antigravity-mission-control.exportToken",
        "title": "Antigravity: Export Refresh Token",
        "icon": "$(export)"
      },
      {
        "command": "antigravity-mission-control.batchExportTokens",
        "title": "Antigravity: Batch Export All Tokens",
        "icon": "$(export)"
      },
      {
        "command": "antigravity-mission-control.batchImportTokens",
        "title": "Antigravity: Batch Import Tokens",
        "icon": "$(import)"
      },
      {
        "command": "antigravity-mission-control.quickSwitch",
        "title": "Antigravity: Quick Switch to Healthiest Account",
        "icon": "$(zap)"
      }
    ],
    "keybindings": [
      {
        "command": "antigravity-mission-control.quickSwitch",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Antigravity Mission Control",
      "properties": {
        "antigravity-mission-control.switchMode": {
          "type": "string",
          "enum": [
            "safe",
            "advanced"
          ],
          "default": "advanced",
          "description": "%config.switchMode.description%"
        },
        "antigravity-mission-control.databasePathOverride": {
          "type": "string",
          "default": "",
          "description": "%config.databasePathOverride.description%"
        },
        "antigravity-mission-control.antigravityExecutablePath": {
          "type": "object",
          "properties": {
            "win32": {
              "type": "string",
              "default": "",
              "description": "%config.antigravityExecutablePath.win32.description%"
            },
            "darwin": {
              "type": "string",
              "default": "",
              "description": "%config.antigravityExecutablePath.darwin.description%"
            },
            "linux": {
              "type": "string",
              "default": "",
              "description": "%config.antigravityExecutablePath.linux.description%"
            }
          }
        },
        "antigravity-mission-control.processWaitSeconds": {
          "type": "integer",
          "default": 10,
          "minimum": 5,
          "maximum": 60,
          "description": "%config.processWaitSeconds.description%"
        },
        "antigravity-mission-control.autoRefreshInterval": {
          "type": "integer",
          "default": 5,
          "enum": [
            0,
            1,
            5,
            10,
            15
          ],
          "description": "Auto-refresh interval in minutes (0 to disable)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/vsce": "^2.19.0",
    "eslint": "^8.41.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "sql.js": "^1.14.1"
  }
}
